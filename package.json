{
  "name": "next-interactive-boilerplate",
  "description": "A Next.js App Router starter kit with TailwindCSS, Sanity, Framer Motion, and GSAP preconfigured",
  "author": "Hendhy Hutomo <hello@hendhyhutomo.com><hendhy@tomostudio.id>, Sam Goddard <hello@samgoddard.co.uk> (https://samgoddard.co.uk)",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git@github.com:tomostudio/next-interactive-starter.git"
  },
  "license": "ISC",
  "keywords": [
    "nextjs",
    "next",
    "tailwind",
    "framer",
    "motion",
    "preact"
  ],
  "homepage": "https://starter.tomostudio.id/",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "skills:create": "node .agents/scripts/create-skill.mjs",
    "skills:sync": "yarn run skills:sync-registry && yarn run skills:sync-claude",
    "skills:sync-claude": "node .agents/scripts/sync-claude-skills.mjs",
    "skills:sync-registry": "node .agents/scripts/sync-skill-registry.mjs",
    "skills:validate": "node .agents/scripts/validate-skills.mjs",
    "session:status": "node ./scripts/start-session.mjs",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check:write": "biome check --write ."
  },
  "dependencies": {
    "@sanity/client": "^7.20.0",
    "@sanity/image-url": "^2.0.3",
    "@sanity/vision": "^5.18.0",
    "@studio-freight/lenis": "^1.0.42",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "locomotive-scroll": "4.1.4",
    "next": "^16.2.1",
    "next-sanity": "^12.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-locomotive-scroll": "^0.2.2",
    "refractor": "3.6.0",
    "sanity": "^5.18.0",
    "sass": "^1.98.0",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3"
  }
}
